{
	"name": "api-extractor-llms",
	"version": "0.1.0",
	"description": "Render Microsoft API Extractor models into LLM-lean markdown. Pure model loading, TSDoc extraction, type-signature formatting, and per-item markdown rendering.",
	"keywords": ["api-extractor", "tsdoc", "llms", "documentation", "markdown", "typescript", "esm"],
	"homepage": "https://github.com/spencerbeggs/api-extractor-llms#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/api-extractor-llms/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/api-extractor-llms.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "rslib build --config-loader native --env-mode dev",
		"build:prod": "rslib build --config-loader native --env-mode npm",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run",
		"ci:version": "savvy changeset version && biome format --write .",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@microsoft/api-extractor-model": "^7.33.8",
		"@microsoft/tsdoc": "^0.16.0"
	},
	"devDependencies": {
		"@savvy-web/rslib-builder": "^0.21.3",
		"@savvy-web/silk": "^0.3.1",
		"@savvy-web/vitest": "^1.4.0",
		"@types/node": "catalog:silk"
	},
	"peerDependencies": {
		"@types/node": "catalog:silkPeers",
		"@typescript/native-preview": "catalog:silkPeers",
		"typescript": "catalog:silkPeers"
	},
	"peerDependenciesMeta": {
		"@types/node": {
			"optional": false
		},
		"@typescript/native-preview": {
			"optional": false
		},
		"typescript": {
			"optional": false
		}
	},
	"packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.3.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/github",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
