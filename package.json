{
	"name": "api-extractor-llms",
	"version": "0.2.0",
	"description": "Render Microsoft API Extractor models into LLM-lean markdown. Pure model loading, TSDoc extraction, type-signature formatting, and per-item markdown rendering.",
	"keywords": ["api-extractor", "tsdoc", "llms", "documentation", "markdown", "typescript", "esm"],
	"homepage": "https://github.com/spencerbeggs/api-extractor-llms#readme",
	"bugs": {
		"url": "https://github.com/spencerbeggs/api-extractor-llms/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spencerbeggs/api-extractor-llms.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@beggs.codes",
		"url": "https://spencerbeg.gs"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped --log-prefix=none",
		"build:dev": "node savvy.build.ts --target dev",
		"build:prod": "node savvy.build.ts --target prod",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full --log-prefix=none",
		"ci:test": "CI=\"true\" vitest run --passWithNoTests",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --passWithNoTests",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@microsoft/api-extractor-model": "^7.33.10",
		"@microsoft/tsdoc": "^0.16.0"
	},
	"devDependencies": {
		"@savvy-web/bundler": "^2.0.8",
		"@savvy-web/silk": "^3.1.2",
		"@types/node": "catalog:silk",
		"@vitest-agent/plugin": "^2.0.6",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@types/node": "catalog:silkPeers",
		"@typescript/native-preview": "catalog:silkPeers",
		"typescript": "catalog:silkPeers"
	},
	"peerDependenciesMeta": {
		"@types/node": {
			"optional": false
		},
		"@typescript/native-preview": {
			"optional": false
		},
		"typescript": {
			"optional": false
		}
	},
	"packageManager": "pnpm@11.16.0+sha512.b767e9a98fc87aec0f42daefcd0e84941c2cdb45d73c4e1e68860fb2bdfdbe032ab592105479e5e05c237f740c8a5ffdbbb52385797ddc2296745a1bbb883e8d",
	"engines": {
		"node": ">=24.11.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.16.0+sha512.b767e9a98fc87aec0f42daefcd0e84941c2cdb45d73c4e1e68860fb2bdfdbe032ab592105479e5e05c237f740c8a5ffdbbb52385797ddc2296745a1bbb883e8d",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.5.0",
				"onFail": "ignore"
			}
		]
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev/pkg",
		"linkDirectory": true,
		"targets": {
			"npm": true,
			"github": "@spencerbeggs/api-extractor-llms"
		}
	}
}
